{
  "name": "techfinder",
  "version": "1.0.0",
  "description": "technician finder application",
  "keywords": [
    "mern",
    "mongodb",
    "node",
    "react",
    "express",
    "jwt",
    "redis",
    "websocket",
    "mapbox",
    "javascript"
  ],
  "license": "ISC",
  "author": "Parvesh Nigam",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "worker": "nodemon src/workers/server.js",
    "all": "concurrently \"npm run dev\" \"npm run worker\"",
    "start": "node src/server.js"
  },
  "imports": {
    "#utils/*": "./src/utils/*.js",
    "#config/*": "./src/config/*.js",
    "#modules/*": "./src/modules/*.js",
    "#middlewares/*": "./src/middlewares/*.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node": "^25.9.0",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3"
  }
}
