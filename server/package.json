{
  "name": "techfinder",
  "version": "1.0.0",
  "description": "technician finder application",
  "keywords": [
    "mern",
    "postgre",
    "postgis",
    "redis",
    "redisgeo",
    "bullmq",
    "node",
    "react",
    "express",
    "jwt",
    "websocket",
    "mapbox",
    "javascript"
  ],
  "license": "ISC",
  "author": "Parvesh Nigam",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "worker": "nodemon src/bootstrap/redis.bootstrap.js",
    "all": "concurrently \"npm run dev\" \"npm run worker\"",
    "start": "node src/server.js"
  },
  "imports": {
    "#shared": "./src/shared/index.js",
    "#shared/*": "./src/shared/*",
    "#infra": "./src/infra/index.js",
    "#infra/*": "./src/infra/*",
    "#queues": "./src/queues/index.js",
    "#queues/*": "./src/queues/*",
    "#config/*": "./src/config/*",
    "#repositories/*": "./src/repositories/*",
    "#middlewares/*": "./src/middlewares/*",
    "#lib/*": "./src/lib/*",
    "#bootstrap/*": "./src/bootstrap/*",
    "#services": "./src/services/index.js",
    "#modules/*": "./src/modules/*",
    "#users/*": "./src/modules/users/*",
    "#auth/*": "./src/modules/auth/*",
    "#technicians/*": "./src/modules/technicians/*",
    "#bookings/*": "./src/modules/bookings/*",
    "#notifications/*": "./src/modules/notifications/*",
    "#realtime/*": "./src/realtime/*"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http": "^0.0.1-security",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node": "^25.9.0",
    "nodemailer": "^8.0.7",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "twilio": "^6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3"
  }
}
